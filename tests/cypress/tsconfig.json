{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["cypress", "node"]
  },
  "include": [
    "./**/*.ts",
    "../../models/cypress/**/*.ts"
  ]
}
